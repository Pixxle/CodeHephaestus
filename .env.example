# Solomon — environment variables
# These are referenced by solomon.yaml via ${VAR_NAME} syntax.
# Secrets should live here, not in the YAML file.

# --- Jira ---
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_PROJECT=PROJ
JIRA_API_KEY=
JIRA_EMAIL=bot@yourorg.com

# --- Slack (optional) ---
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C012....
# SLACK_STANDUP_CHANNEL_ID=C0123...

# --- Figma (optional) ---
# FIGMA_ACCESS_TOKEN=
